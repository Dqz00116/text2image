# OpenRouter API key — required for generate and openrouter backend
OPENROUTER_API_KEY=sk-or-v1-your-api-key-here

# --- generate defaults ---

# Model ID for image generation
TEXT2IMAGE_MODEL=openai/gpt-5.4-image-2

# Default output file path
TEXT2IMAGE_OUTPUT=output/output.png

# Default aspect ratio (1:1, 16:9, 9:16, etc.)
TEXT2IMAGE_ASPECT_RATIO=1:1

# Default image resolution (1K, 2K, 4K)
TEXT2IMAGE_IMAGE_SIZE=1K

# --- Shared ---

# OpenRouter API base URL (used by both generate and describe)
OPENROUTER_API_BASE=https://openrouter.ai/api/v1

# --- describe defaults ---

# Vision backend: "kimi" (local CLI) or "openrouter" (API)
DESCRIBE_BACKEND=kimi

# Path to kimi executable (when backend=kimi)
KIMI_PATH=kimi

# Python version to run kimi via uv (e.g. "3.13"), bypasses Python 3.14 incompatibility
KIMI_PYTHON=3.13

# Timeout in seconds for image description
DESCRIBE_TIMEOUT=60

# Vision model ID (when backend=openrouter)
DESCRIBE_VISION_MODEL=moonshotai/kimi-k2.5

# Default prompt used when describe is called without a prompt argument
DESCRIBE_DEFAULT_PROMPT=Please describe this image in detail, focusing on style, composition, colors, subjects, and mood.
